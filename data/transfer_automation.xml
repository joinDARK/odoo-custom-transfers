<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Серверное действие -->
    <record id="action_log_transfer_data" model="ir.actions.server">
        <field name="name">Вывести данные перевода</field>
        <field name="model_id" ref="model_custom_transfer"/>
        <field name="state">code</field>
        <field name="code">
            if record.execute_automation:
                # Вызываем метод для логирования
                record.log_transfer_data()
                # Сбрасываем флаг после выполнения
                record.write({'execute_automation': False})
        </field>
    </record>

    <!-- Правило автоматизации -->
    <record id="transfer_automation_rule" model="base.automation">
        <field name="name">Автоматизация: Вывод данных перевода</field>
        <field name="model_id" ref="model_custom_transfer"/>
        <field name="trigger">on_write</field>
        <field name="active">True</field>
        <field name="filter_pre_domain">[('execute_automation', '=', True)]</field>
        <field name="action_server_id" ref="action_log_transfer_data"/>
    </record>
</odoo>