<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Список Plательщиков -->
    <record id="payer_list_view" model="ir.ui.view">
        <field name="name">payer.list</field>
        <field name="model">custom.payer</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="bank_account"/>
            </list>
        </field>
    </record>

    <!-- 2. Форма Plательщика -->
    <record id="payer_form_view" model="ir.ui.view">
        <field name="name">payer.form</field>
        <field name="model">custom.payer</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="bank_account"/>
                    </group>
                </sheet>
                <!-- Виджет трекинга -->
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- 3. Действие (action) Plательщиков -->
    <record id="payer_action" model="ir.actions.act_window">
        <field name="name">Плательщики</field>
        <field name="res_model">custom.payer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

